$uid = $_SESSION['uid'];

/* ==========================
   FETCH USER REPORTS
   ========================== */
$query = "
SELECT 
    ru.id AS upload_id,
    ru.road_image,
    ru.area_name,
    ru.street_name,
    ru.upload_time,
    ar.defect_type,
    ar.severity,
    ar.confidence,
    ar.analyzed_at
FROM road_uploads ru
JOIN analysis_results ar ON ru.id = ar.upload_id
WHERE ru.user_id = '$uid'
ORDER BY ru.upload_time DESC
";

$result = mysqli_query($con, $query);
?>

